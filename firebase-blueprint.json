{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and statistics",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "streak": { "type": "integer" },
        "lastEntryDate": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Entry": {
      "title": "Diary Entry",
      "description": "A personal diary entry with mood and optional challenge reference",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "mood": { "type": "string", "enum": ["great", "good", "neutral", "sad", "awful"] },
        "content": { "type": "string" },
        "challengeId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "date", "mood", "content", "createdAt"]
    },
    "Challenge": {
      "title": "Daily Challenge",
      "description": "A challenge to inspire the user",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "icon": { "type": "string" }
      },
      "required": ["title", "description"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/users/{userId}/entries/{entryId}": {
      "schema": "Entry",
      "description": "Diary entries for a user"
    },
    "/challenges/{challengeId}": {
      "schema": "Challenge",
      "description": "Global list of available challenges"
    }
  }
}
